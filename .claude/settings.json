{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(dotnet build:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet run:*)",
      "Bash(dotnet ef migrations add:*)",
      "Bash(dotnet ef migrations remove:*)",
      "Bash(dotnet ef migrations list:*)",
      "Bash(dotnet ef database update:*)",
      "Bash(dotnet user-secrets:*)",
      "Bash(dotnet --version:*)",
      "Bash(dotnet --info:*)",
      "Bash(dotnet tool list:*)",
      "Bash(dotnet new:*)",
      "Bash(dotnet add:*)",
      "Bash(dotnet remove package:*)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git rm --cached:*)",
      "Bash(git config --get:*)",
      "Bash(git credential fill:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",

      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh label:*)",
      "Bash(gh auth status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh api:*)",
      "Bash(gh workflow:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(where:*)",
      "Bash(openssl rand:*)",

      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "NotebookEdit"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git branch -D:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(dotnet ef database drop:*)",
      "Bash(dotnet ef migrations remove --force:*)"
    ]
  }
}
